{
  "name": "sea-tecnologia-desafio-qa-automacao",
  "version": "2.0.0",
  "private": true,
  "description": "Suítes de automação (Cypress e Playwright) para o Desafio Analista de Teste — SEA Tecnologia",
  "scripts": {
    "test:cypress": "env -u ELECTRON_RUN_AS_NODE cypress run",
    "test:cypress:headed": "env -u ELECTRON_RUN_AS_NODE cypress run --headed --browser chrome",
    "test:cypress:open": "env -u ELECTRON_RUN_AS_NODE cypress open",
    "test:playwright": "playwright test",
    "test:playwright:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "cypress": "^13.17.0"
  }
}
